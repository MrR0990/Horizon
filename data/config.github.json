    "reddit": {
      "enabled": true,
      "subreddits": [
        { "subreddit": "androiddev",           "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "iOSProgramming",       "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 30 },
        { "subreddit": "MachineLearning",      "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 50 },
        { "subreddit": "LocalLLaMA",           "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 20, "min_score": 50 },
        { "subreddit": "hardware",             "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 100 },
        { "subreddit": "learnmachinelearning", "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 15, "min_score": 30 }
      ],
      "fetch_comments": 3
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["Python", "TypeScript", "Kotlin", "Swift"],
      "keywords": ["llm", "ai", "android", "ios"],
      "min_stars": 20,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": null,
    "category_groups": {
      "mobile":      { "limit": 5, "categories": ["android-ios"] },
      "ai-tools":    { "limit": 4, "categories": ["claude-ai"] },
      "hardware":    { "limit": 5, "categories": ["hardware"] },
      "ai-libs":     { "limit": 5, "categories": ["ai-opensource"] },
      "ai-eng":      { "limit": 4, "categories": ["ai-engineering"] },
      "devops":      { "limit": 4, "categories": ["devops"] },
      "startup":     { "limit": 5, "categories": ["startup-biz"] },
      "finance":     { "limit": 4, "categories": ["finance"] },
      "ai-learning": { "limit": 5, "categories": ["ai-learning"] },
      "lang-skills": { "limit": 4, "categories": ["lang-skills"] }
    },
    "default_group": "other",
    "default_group_limit": 3
  }
}
