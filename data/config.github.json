{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 2,
    "languages": [
      "en",
      "zh"
    ]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 40,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Android Police",
        "url": "https://www.androidpolice.com/feed/",
        "enabled": true,
        "category": "android-ios"
      },
      {
        "name": "9to5Google",
        "url": "https://9to5google.com/feed/",
        "enabled": true,
        "category": "android-ios"
      },
      {
        "name": "9to5Mac",
        "url": "https://9to5mac.com/feed/",
        "enabled": true,
        "category": "android-ios"
      },
      {
        "name": "MacRumors",
        "url": "https://feeds.macrumors.com/MacRumors-All",
        "enabled": true,
        "category": "android-ios"
      },
      {
        "name": "Latent Space (AI Engineering)",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "claude-ai"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "claude-ai"
      },
      {
        "name": "The Pragmatic Engineer",
        "url": "https://newsletter.pragmaticengineer.com/feed",
        "enabled": true,
        "category": "claude-ai"
      },
      {
        "name": "The Verge",
        "url": "https://www.theverge.com/rss/index.xml",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "GSMArena",
        "url": "https://www.gsmarena.com/rss-news-reviews.php3",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "AnandTech",
        "url": "https://www.anandtech.com/rss/",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "Tom's Hardware",
        "url": "https://www.tomshardware.com/feeds/all",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-opensource"
      },
      {
        "name": "Papers With Code",
        "url": "https://paperswithcode.com/rss",
        "enabled": true,
        "category": "ai-opensource"
      },
      {
        "name": "LangChain Blog",
        "url": "https://blog.langchain.dev/rss/",
        "enabled": true,
        "category": "ai-opensource"
      },
      {
        "name": "IT之家",
        "url": "https://www.ithome.com/rss/",
        "enabled": true,
        "category": "hardware"
      },
      {
        "name": "Eugene Yan (AI Engineering)",
        "url": "https://eugeneyan.com/rss/",
        "enabled": true,
        "category": "ai-engineering"
      },
      {
        "name": "Chip Huyen (AI Systems)",
        "url": "https://huyenchip.com/feed.xml",
        "enabled": true,
        "category": "ai-engineering"
      },
      {
        "name": "GitLab Blog",
        "url": "https://about.gitlab.com/atom.xml",
        "enabled": true,
        "category": "devops"
      },
      {
        "name": "LeadDev",
        "url": "https://leaddev.com/feed",
        "enabled": true,
        "category": "devops"
      },
      {
        "name": "InfoQ",
        "url": "https://feed.infoq.com/",
        "enabled": true,
        "category": "devops"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "androiddev",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "iOSProgramming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 50
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 50
        },
        {
          "subreddit": "hardware",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 100
        }
      ],
      "fetch_comments": 3
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "Python",
        "TypeScript",
        "Kotlin",
        "Swift"
      ],
      "keywords": [
        "llm",
        "ai",
        "android",
        "ios"
      ],
      "min_stars": 20,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": null,
    "category_groups": {
      "mobile": {
        "limit": 5,
        "categories": [
          "android-ios"
        ]
      },
      "ai-tools": {
        "limit": 4,
        "categories": [
          "claude-ai"
        ]
      },
      "hardware": {
        "limit": 5,
        "categories": [
          "hardware"
        ]
      },
      "ai-libs": {
        "limit": 5,
        "categories": [
          "ai-opensource"
        ]
      },
      "ai-eng": {
        "limit": 4,
        "categories": [
          "ai-engineering"
        ]
      },
      "devops": {
        "limit": 4,
        "categories": [
          "devops"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  }
}