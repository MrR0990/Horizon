      { "name": "Hugging Face Blog",       "url": "https://huggingface.co/blog/feed.xml",                   "enabled": true, "category": "ai-opensource" },
      { "name": "Papers With Code",        "url": "https://paperswithcode.com/rss",                         "enabled": true, "category": "ai-opensource" },
